# Copy to .env and fill in real values
# Server
PORT=3001
NODE_ENV=development

# MongoDB (leave blank to use local JSON file)
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-strong-random-secret
# 32+ char secret used for AES-256-GCM field encryption (PII). Falls back to JWT_SECRET if unset.
ENCRYPTION_KEY=replace-with-strong-32plus-char-secret

# Judge0 API
JUDGE0_URL=https://ce.judge0.com

# OpenRouter AI
OPENROUTER_API_KEY=

# Frontend
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# UPI Payment
UPI_ID=
UPI_PAYEE_NAME=CodeSprout
UPI_CURRENCY=INR
PREMIUM_AMOUNT=49
SUBSCRIPTION_DAYS=30

# Razorpay (https://dashboard.razorpay.com/app/keys)
# Use rzp_test_xxx for development, rzp_live_xxx for production
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Email / SMTP (Gmail: enable 2FA, create App Password at https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=CodeSprout <noreply@codesprout.com>
