{
  "name": "dsa-cheatsheets-backend",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:auth": "tsx watch src/services/auth.ts",
    "dev:content": "tsx watch src/services/content.ts",
    "dev:social": "tsx watch src/services/social.ts",
    "dev:execution": "tsx watch src/services/execution.ts",
    "dev:payment": "tsx watch src/services/payment.ts",
    "dev:resume": "tsx watch src/services/resume.ts",
    "dev:gateway": "tsx watch src/services/gateway.ts",
    "dev:microservices": "concurrently -n AUTH,CONTENT,SOCIAL,EXEC,PAY,GATE,RESUME -c blue,green,yellow,magenta,cyan,white,red \"npm:dev:auth\" \"npm:dev:content\" \"npm:dev:social\" \"npm:dev:execution\" \"npm:dev:payment\" \"npm:dev:gateway\" \"npm:dev:resume\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:auth": "node dist/services/auth.js",
    "start:content": "node dist/services/content.js",
    "start:social": "node dist/services/social.js",
    "start:execution": "node dist/services/execution.js",
    "start:payment": "node dist/services/payment.js",
    "start:resume": "node dist/services/resume.js",
    "start:gateway": "node dist/services/gateway.js",
    "health": "powershell -File health-check.ps1",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop all",
    "pm2:delete": "pm2 delete all",
    "pm2:restart": "pm2 restart all",
    "pm2:reload": "pm2 reload all",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    "pm2:save": "pm2 save",
    "pm2:status": "pm2 list"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.13.9",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.9.0",
    "mongodb": "^6.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.2",
    "razorpay": "^2.9.6",
    "tsx": "^4.16.2",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "pm2": "^7.0.1"
  }
}
